# Required
PAPERLESS_API_TOKEN=
DOMAIN=domain.fr

# SMTP config
SMTP_LISTEN_ADDR=:25
SMTP_HOSTNAME=mail.domain.fr

# Paperless
PAPERLESS_URL=http://paperless:8000

# OVH API (optional - auto-configures DNS/MX)
OVH_ENDPOINT=ovh-eu
OVH_APP_KEY=
OVH_APP_SECRET=
OVH_CONSUMER_KEY=

# Subdomain for MX (default: docs)
SUBDOMAIN=docs

# Security: space-separated list of allowed senders
# Leave empty to accept from anyone
ALLOWED_SENDERS=

# Dynamic DNS: auto-update A record when public IP changes
DDNS_ENABLED=true
DDNS_INTERVAL=5m
